# ─────────────────────────────────────────────────────────────────────────────
# .containerignore — agent-eval build context filter
#
# Used with:
#   podman build --ignorefile .containerignore
#   docker build (place at repo root or pass via .dockerignore symlink)
#
# Goal: keep the build context small and prevent secrets / build artifacts
# from being sent to the container daemon.
# ─────────────────────────────────────────────────────────────────────────────

# ── Rust build artifacts (can be gigabytes) ───────────────────────────────────
target/
**/target/
**/*.rs.bk
**/mutants.out*/

# ── Node / frontend artifacts ─────────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitmodules

# ── Secrets and local credentials — never send to the daemon ─────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.jks
~/.claude/
~/.config/gestura/
~/.gestura/

# ── Temporary and ephemeral files ─────────────────────────────────────────────
.tmp/
.tmp-agent-runs/
*.tmp

# ── macOS filesystem noise ────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── IDE and editor files ──────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.augment/

# ── CI/CD config (not needed at runtime) ─────────────────────────────────────
.github/
.gitlab-ci.yml
.circleci/

# ── Documentation (not needed for the build) ─────────────────────────────────
docs/
*.md
!README.md

# ── Reports and output artefacts ─────────────────────────────────────────────
# Local suite run output directories (created by `agent-eval suite --output-dir`)
eval-results/
reports/
eval-*.json
comparison-*.json
report-*.html

# ── GUI crate source (never compiled in the eval image) ──────────────────────
crates/gestura-gui/

